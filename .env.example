# Privy — wallet login + embedded wallets (client-side app id).
# Get it from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Zerion — live portfolio data. Stays server-side (never exposed to the browser).
# https://developers.zerion.io/authentication
ZERION_API_KEY=

# GenLayer — the chatbot brain. Deploy contracts/chatbot.py and paste the address.
NEXT_PUBLIC_GENLAYER_NETWORK=studionet
NEXT_PUBLIC_GENLAYER_CONTRACT_ADDRESS=

# Only needed to run scripts/deploy-genlayer.ts (never required by the web app):
# GENLAYER_PRIVATE_KEY=
